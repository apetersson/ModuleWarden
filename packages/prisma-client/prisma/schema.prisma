// ── ModuleWarden Prisma Schema ────────────────────────────────────
// v1 — Application DB access layer. All reads/writes go through Prisma.
// pg-boss manages its own internal tables; this schema owns review/audit/decision rows.
// No ad hoc SQL clients or alternative ORMs for normal product data.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Projects ──────────────────────────────────────────────────────
model Project {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String?
  graphState    GraphState  @default(IMPORTING)
  registryEnabled Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lockfileImports       LockfileImport[]
  packageSubscriptions  PackageSubscription[]
  importedPackageVersions ImportedPackageVersion[]
  reAuditCampaigns      ReAuditCampaign[]
}

enum GraphState {
  IMPORTING
  AUDITING
  READY
}

// ── Lockfile Imports ──────────────────────────────────────────────
model LockfileImport {
  id           String   @id @default(uuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id])
  lockfilePath String
  importedAt   DateTime @default(now())
  packageCount Int
  createdAt    DateTime @default(now())
}

// ── Package Subscriptions ─────────────────────────────────────────
model PackageSubscription {
  id             String   @id @default(uuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id])
  packageName    String
  registrySource String @default("npm")
  subscribedAt   DateTime @default(now())
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  upstreamMetadataSnapshots UpstreamMetadataSnapshot[]

  @@unique([projectId, packageName, registrySource])
}

// ── Upstream Metadata Snapshots ───────────────────────────────────
model UpstreamMetadataSnapshot {
  id             String   @id @default(uuid())
  subscriptionId String
  subscription   PackageSubscription @relation(fields: [subscriptionId], references: [id])
  packageName    String
  registrySource String @default("npm")
  metadata       Json
  fetchedAt      DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([subscriptionId, fetchedAt])
}

// ── Package Versions ──────────────────────────────────────────────
model PackageVersion {
  id                String   @id @default(uuid())
  packageName       String
  version           String
  registrySource    String   @default("npm")
  tarballHash       String
  tarballSize       Int?
  publishDate       DateTime?
  deprecated        Boolean  @default(false)
  description       String?
  repositoryUrl     String?
  homepageUrl       String?
  license           String?
  hasLifecycleScript Boolean @default(false)
  hasObfuscation    Boolean @default(false)
  hasNativeBinary   Boolean @default(false)
  hasWasm           Boolean @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  predecessorId     String?
  predecessor       PackageVersion? @relation("PredecessorLink", fields: [predecessorId], references: [id])

  tarballArtifacts      TarballArtifact[]
  reviewJobs            ReviewJob[]
  importedByProjects    ImportedPackageVersion[]
  predecessorOf         PackageVersion[] @relation("PredecessorLink")
  predecessorDecisions  Decision[]       @relation("PredecessorDecision")

  @@unique([packageName, version, registrySource, tarballHash])
  @@index([packageName, registrySource])
  @@index([tarballHash])
}

// ── Exact Imported Project Graph ─────────────────────────────────
model ImportedPackageVersion {
  id               String @id @default(uuid())
  projectId        String
  project          Project @relation(fields: [projectId], references: [id])
  packageVersionId String
  packageVersion   PackageVersion @relation(fields: [packageVersionId], references: [id])
  lockfileImportId String?
  importedAt       DateTime @default(now())

  @@unique([projectId, packageVersionId])
  @@index([projectId])
  @@index([packageVersionId])
}

// ── Tarball Artifacts ──────────────────────────────────────────────
model TarballArtifact {
  id               String @id @default(uuid())
  packageVersionId String
  packageVersion   PackageVersion @relation(fields: [packageVersionId], references: [id])
  storagePath      String
  fileCount        Int?
  totalSizeBytes   Int?
  createdAt        DateTime @default(now())

  @@index([packageVersionId])
}

// ── Review Jobs ────────────────────────────────────────────────────
model ReviewJob {
  id               String @id @default(uuid())
  packageVersionId String
  packageVersion   PackageVersion @relation(fields: [packageVersionId], references: [id])
  auditContext     String
  trigger          ReviewTrigger
  status           JobStatus @default(PENDING)
  pgBossJobId      String?
  idempotencyKey   String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  auditRuns    AuditRun[]
  decisions    Decision[]

  @@unique([packageVersionId, auditContext])
  @@index([status])
  @@index([idempotencyKey])
}

enum ReviewTrigger {
  PREFLIGHT
  SUBSCRIPTION
  MANUAL
  RE_AUDIT
}

enum JobStatus {
  PENDING
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  DEAD_LETTER
}

// ── Audit Runs ────────────────────────────────────────────────────
model AuditRun {
  id            String   @id @default(uuid())
  reviewJobId   String
  reviewJob     ReviewJob @relation(fields: [reviewJobId], references: [id])
  containerId   String?
  containerName String?
  status        RunStatus @default(PENDING)
  startedAt     DateTime?
  completedAt   DateTime?
  timeoutAt     DateTime?
  errorMessage  String?
  piSessionId   String?
  piRunId       String?
  rpcTokenHash  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  evidenceArtifacts EvidenceArtifact[]

  @@index([reviewJobId])
  @@index([piSessionId])
}

enum RunStatus {
  PENDING
  RUNNING
  COMPLETED
  TIMED_OUT
  CRASHED
  CANCELLED
}

// ── Prompt Packs ──────────────────────────────────────────────────
model PromptPack {
  id        String   @id @default(uuid())
  name      String
  version   String
  category  PromptCategory
  content   String
  hash      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  decisions Decision[] @relation("PromptDecisions")

  @@unique([name, version])
}

enum PromptCategory {
  CORE
  CUSTOM_ADMIN
  ESCALATION
  PATTERN_CHECK
}

// ── Model Profiles ────────────────────────────────────────────────
model ModelProfile {
  id         String   @id @default(uuid())
  name       String   @unique
  baseUrl    String
  modelName  String
  apiKeyHash String?
  temperature Float?
  maxTokens  Int?
  isFallback Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  decisions Decision[] @relation("ModelDecisions")
}

// ── Evidence Artifacts ─────────────────────────────────────────────
model EvidenceArtifact {
  id            String   @id @default(uuid())
  auditRunId    String
  auditRun      AuditRun @relation(fields: [auditRunId], references: [id])
  artifactType  EvidenceType
  name          String
  content       Json
  contentHash   String
  filePath      String?
  sizeBytes     Int?
  createdAt     DateTime @default(now())

  decisions        Decision[] @relation("DecisionEvidence")
  evaluationLabels EvaluationLabel[]
}

enum EvidenceType {
  DIFF_SUMMARY
  DEPENDENCY_DIFF
  LIFECYCLE_SCRIPT_CHANGES
  CAPABILITY_DELTA
  OBFUSCATION_INDICATORS
  NATIVE_WASM_ADDITIONS
  CHANGELOG_CONTEXT
  REPOSITORY_SOURCE
  SANDBOX_INSTALL_TRACE
  NETWORK_EGRESS_TRACE
  PI_SESSION_METADATA
  PROMPT_VERSION
  MODEL_VERSION
  SCORES
  REVIEWER_SUMMARY
  STATIC_RULE_RESULTS
  DECOMPILED_OUTPUT
  OTHER
}

// ── Decisions ──────────────────────────────────────────────────────
model Decision {
  id               String   @id @default(uuid())
  reviewJobId      String
  reviewJob        ReviewJob  @relation(fields: [reviewJobId], references: [id])
  packageVersionId String
  packageVersion   PackageVersion @relation("PredecessorDecision", fields: [packageVersionId], references: [id])
  verdict          Verdict
  reasonSummary    String
  predecessorVersion String?
  predecessorHash  String?
  promptVersion    String?
  promptPackId     String?
  promptPack       PromptPack?    @relation("PromptDecisions", fields: [promptPackId], references: [id])
  modelProfileId   String?
  modelProfile     ModelProfile?  @relation("ModelDecisions", fields: [modelProfileId], references: [id])
  scores           Json?
  actorType        ActorType
  piSessionId      String?
  piRunId          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  scoresData        Score[]
  evidenceArtifacts EvidenceArtifact[] @relation("DecisionEvidence")
  evaluationLabels  EvaluationLabel[]
  overrides         Override[]
  reAuditCampaigns  ReAuditCampaign[] @relation("CampaignDecisions")

  @@index([packageVersionId, verdict])
  @@index([reviewJobId])
  @@index([promptPackId])
  @@index([modelProfileId])
}

enum Verdict {
  ALLOW
  BLOCK
  QUARANTINE
}

enum ActorType {
  AGENT
  ADMIN
}

// ── Scores ─────────────────────────────────────────────────────────
model Score {
  id         String @id @default(uuid())
  decisionId String
  decision   Decision @relation(fields: [decisionId], references: [id])
  name       String
  value      Float
  weight     Float?
  category   String?
  createdAt  DateTime @default(now())

  @@index([decisionId])
  @@index([name, value])
}

// ── Overrides ─────────────────────────────────────────────────────
model Override {
  id                    String   @id @default(uuid())
  decisionId            String
  decision              Decision @relation(fields: [decisionId], references: [id])
  adminIdentity         String
  scope                 OverrideScope
  targetVerdict         Verdict @default(ALLOW)
  reason                String
  supersedesDecisionId  String?
  active                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([decisionId])
  @@index([adminIdentity])
}

enum OverrideScope {
  SPECIFIC_VERSION
  PACKAGE
  PROJECT
  GLOBAL
}

// ── Re-Audit Campaigns ────────────────────────────────────────────
model ReAuditCampaign {
  id                String   @id @default(uuid())
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id])
  reason            String
  triggerType       ReAuditTrigger
  promptPackId      String?
  modelProfileId    String?
  patternDefinition String?
  status            CampaignStatus @default(PENDING)
  createdAt         DateTime @default(now())
  completedAt       DateTime?
  updatedAt         DateTime @updatedAt

  decisions Decision[] @relation("CampaignDecisions")
}

enum ReAuditTrigger {
  PROMPT_CHANGE
  MODEL_CHANGE
  PATTERN_CHANGE
  ADMIN_REQUEST
  SCHEDULED
}

enum CampaignStatus {
  PENDING
  RUNNING
  COMPLETED
  CANCELLED
}

// ── Evaluation Labels ──────────────────────────────────────────────
model EvaluationLabel {
  id                  String   @id @default(uuid())
  decisionId          String
  decision            Decision  @relation(fields: [decisionId], references: [id])
  evidenceArtifactId  String?
  evidenceArtifact    EvidenceArtifact? @relation(fields: [evidenceArtifactId], references: [id])
  labelType           LabelType
  labelValue          String
  labelDescription    String?
  labeledBy           String
  createdAt           DateTime @default(now())

  @@index([decisionId])
  @@index([labelType, labelValue])
}

enum LabelType {
  ADMIN_OVERRIDE
  POST_HOC_RELABEL
  INCIDENT_OUTCOME
  EVALUATION_RESULT
}
