{
  "name": "@modulewarden/prisma-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "generate": "prisma generate",
    "migrate": "npx prisma migrate dev",
    "seed:prompt-packs": "prisma generate && node scripts/seed-prompt-packs.mjs",
    "studio": "prisma studio",
    "test": "vitest run"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@modulewarden/shared": "workspace:*",
    "@prisma/client": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "prisma": "^6.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
