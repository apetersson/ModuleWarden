{
  "name": "@modulewarden/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "types": ["dist/types.d.ts"],
      "config": ["dist/config.d.ts"],
      "constants": ["dist/constants.d.ts"],
      "npm-types": ["dist/npm-types.d.ts"],
      "services/*": ["dist/services/*.d.ts"]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.js"
    },
    "./npm-types": {
      "types": "./dist/npm-types.d.ts",
      "import": "./dist/npm-types.js"
    },
    "./services/upstream": {
      "types": "./dist/services/upstream.d.ts",
      "import": "./dist/services/upstream.js"
    },
    "./services/lockfile": {
      "types": "./dist/services/lockfile.d.ts",
      "import": "./dist/services/lockfile.js"
    },
    "./services/package-diff": {
      "types": "./dist/services/package-diff.d.ts",
      "import": "./dist/services/package-diff.js"
    },
    "./services/capability-extract": {
      "types": "./dist/services/capability-extract.d.ts",
      "import": "./dist/services/capability-extract.js"
    },
    "./services/evidence-bundle": {
      "types": "./dist/services/evidence-bundle.d.ts",
      "import": "./dist/services/evidence-bundle.js"
    },
    "./services/rpc-tools": {
      "types": "./dist/services/rpc-tools.d.ts",
      "import": "./dist/services/rpc-tools.js"
    },
    "./services/capability-delta": {
      "types": "./dist/services/capability-delta.d.ts",
      "import": "./dist/services/capability-delta.js"
    },
    "./services/evaluation-corpus": {
      "types": "./dist/services/evaluation-corpus.d.ts",
      "import": "./dist/services/evaluation-corpus.js"
    },
    "./services/evaluation-runner": {
      "types": "./dist/services/evaluation-runner.d.ts",
      "import": "./dist/services/evaluation-runner.js"
    },
    "./services/dashboard": {
      "types": "./dist/services/dashboard.d.ts",
      "import": "./dist/services/dashboard.js"
    },
    "./services/logger": {
      "types": "./dist/services/logger.d.ts",
      "import": "./dist/services/logger.js"
    }
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
