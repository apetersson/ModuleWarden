{
  "name": "@modulewarden/worker",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "jobs": ["dist/jobs/index.d.ts"],
      "jobs/queue.js": ["dist/jobs/queue.d.ts"],
      "jobs/queue": ["dist/jobs/queue.d.ts"]
    }
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsx watch src/index.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jobs": {
      "types": "./dist/jobs/index.d.ts",
      "import": "./dist/jobs/index.js"
    },
    "./jobs/queue.js": {
      "types": "./dist/jobs/queue.d.ts",
      "import": "./dist/jobs/queue.js"
    },
    "./jobs/queue": {
      "types": "./dist/jobs/queue.d.ts",
      "import": "./dist/jobs/queue.js"
    }
  },
  "dependencies": {
    "@modulewarden/shared": "workspace:*",
    "@modulewarden/prisma-client": "workspace:*",
    "@modulewarden/temporal-forecast": "workspace:*",
    "@prisma/client": "^6.0.0",
    "pg-boss": "^11.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.0.0",
    "vitest": "^2.0.0"
  }
}
