# ModuleWarden environment variables.
# Copy to .env at the repo root: `cp .env.example .env`
# `docker compose up -d` will then read these values.
#
# Values marked `<set me>` MUST be replaced before going past dev. The
# defaults below are safe for a local laptop demo on an isolated network.

# ─── Postgres (docker-compose service: postgres) ────────────────────────────
DATABASE_URL=postgresql://modulewarden:modulewarden@postgres:5432/modulewarden?schema=public
MW_POSTGRES_HOST=postgres
MW_POSTGRES_PORT=5432
MW_POSTGRES_DB=modulewarden
MW_POSTGRES_USER=modulewarden
MW_POSTGRES_PASSWORD=modulewarden

# ─── Verdaccio (internal upstream npm mirror) ──────────────────────────────
MW_VERDACCIO_HOST=verdaccio
MW_VERDACCIO_PORT=4873

# ─── Auth tokens (api-proxy + worker) ──────────────────────────────────────
# Rotate these for any non-laptop deployment. Comma-separated lists are
# allowed; the first entry is the default in tooling that asks for one.
MW_AUTH_ADMIN_TOKENS=mw-admin-token-change-me
MW_AUTH_DEV_TOKENS=mw-dev-token-change-me

# ─── LLM audit endpoint (consumed by worker for the optional audit step) ───
# Point at any OpenAI-compatible /v1 endpoint (Ollama, vLLM, hosted OpenAI,
# the internal model-endpoint profile of this compose file, etc.).
# The model-endpoint profile in docker-compose.yml is opt-in:
#   `docker compose --profile model-endpoint up -d`
MW_MODEL_ENDPOINT_BASE_URL=http://model-endpoint:8080/v1
MW_MODEL_ENDPOINT_API_KEY=sk-change-me
MW_MODEL_ENDPOINT_MODEL=llama-3-70b

# ─── Audit container (per-job Docker isolation) ────────────────────────────
MW_AUDIT_IMAGE=modulewarden-audit-runner
# Optional: forwarded to the orchestrator when invoking the agentic harness.
# Without these the orchestrator falls back to the tool-only audit path
# (file-system inspection without PI), which still produces a verdict but is
# annotated `pi_mode=tool-only` in the eval matrix output.
# MW_RPC_PORT=
# MW_RPC_TOKEN=
# MW_AUDIT_TIMEOUT_MS=180000

# ─── Web UI (no env required by default) ───────────────────────────────────
# Vite reads these at build time. Set VITE_API_BASE_URL to point at your
# api-proxy if the UI is served from a different host than the gate.
# VITE_API_BASE_URL=http://localhost:8080

# ─── finetune/python (only needed when running training or eval locally) ────
# HuggingFace hub token, if pulling a gated model checkpoint.
# HF_TOKEN=
# Optional explicit HF cache (otherwise ~/.cache/huggingface).
# HF_HOME=
# W&B for finetune telemetry, optional.
# WANDB_API_KEY=
# WANDB_PROJECT=modulewarden-finetune

# ─── GitHub PAT (vulnerability scraper) ────────────────────────────────────
# Required to raise the GitHub REST API rate limit from 60/hr to 5000/hr
# for finetune/scripts/scrape-cases.mjs. No scopes needed; a token with
# default public_repo read access is sufficient. The scraper only hits
# the public /advisories endpoint.
# Create at: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_change_me

# ─── Nextcloud (isolated storage for scraped malicious data) ───────────────
# The team stores scraped vulnerability cases, attack-pattern variants,
# and sample malicious package tarballs on the AI:AT Factory Nextcloud
# instance rather than committing them to GitHub. The path is fixed at
# /ZeroToOne_Data/finetune-data/ on the instance.
# NEXTCLOUD_URL=https://nextcloud.capacity.at
# NEXTCLOUD_USER=<set me>
# NEXTCLOUD_PASS=<set me>
# NEXTCLOUD_FINETUNE_PATH=/ZeroToOne_Data/finetune-data
