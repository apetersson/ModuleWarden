{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@modulewarden/shared": ["./packages/shared/src"],
      "@modulewarden/prisma-client": ["./packages/prisma-client/src"],
      "@modulewarden/worker": ["./packages/worker/src"],
      "@modulewarden/worker/*": ["./packages/worker/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
