# ModuleWarden environment variables — Leonardo Edition
#
# Copy to .env: cp .env.leonardo-example .env
# Then run: ./scripts/bring-up.sh
#
# This config uses a Leonardo-hosted vLLM endpoint (qwen3.6 27b) for
# agentic audit research. The endpoint is accessed via SSH tunnel:
#   localhost:8081 → leonardo-compute-node:8000

# --- docker compose project name ---
COMPOSE_PROJECT_NAME=modulewarden

# ─── Postgres ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://modulewarden:modulewarden@postgres:5432/modulewarden?schema=public
MW_POSTGRES_HOST=postgres
MW_POSTGRES_PORT=5432
MW_POSTGRES_DB=modulewarden
MW_POSTGRES_USER=modulewarden
MW_POSTGRES_PASSWORD=modulewarden

# ─── Verdaccio ─────────────────────────────────────────────────────────
MW_VERDACCIO_HOST=verdaccio
MW_VERDACCIO_PORT=4873

# ─── Search broker ─────────────────────────────────────────────────────
MW_SEARCH_PROVIDER=searxng
MW_SEARXNG_URL=http://searxng:8080
MW_SEARXNG_SECRET=modulewarden-local-searxng-change-me

# ─── Auth tokens ───────────────────────────────────────────────────────
MW_AUTH_ADMIN_TOKENS=mw-admin-token-change-me
MW_AUTH_DEV_TOKENS=mw-dev-token-change-me

# ─── LLM audit endpoint — Leonardo vLLM (qwen3.6 27b) ──────────────────
# The SSH tunnel maps localhost:8081 → Leonardo compute node:8000.
# vLLM serves an OpenAI-compatible /v1 API with the model name below.
#
# PI uses the "openai" provider with OPENAI_BASE_URL set to this endpoint.
# vLLM ignores the API key, but PI requires one — "vllm" is fine.
MW_MODEL_ENDPOINT_BASE_URL=http://host.docker.internal:8081/v1
MW_MODEL_ENDPOINT_API_KEY=vllm
MW_MODEL_ENDPOINT_MODEL=qwen3.6-27b

# Optional: explicit PI provider override (default: auto-detected from URL)
# MW_MODEL_ENDPOINT_PROVIDER=openai

# Optional: max output tokens per LLM call (default: 16384)
# MW_MODEL_ENDPOINT_MAX_TOKENS=16384

# Optional: max agent turns before timeout (default: 50)
# MW_AUDIT_MAX_TURNS=50

# Optional: audit timeout in milliseconds (default: 600000 = 10 min)
# MW_AUDIT_TIMEOUT_MS=600000

# ─── Audit container ───────────────────────────────────────────────────
MW_AUDIT_IMAGE=modulewarden-audit-runner
MW_PRESERVE_AUDIT_SESSIONS=true
MW_AUDIT_SESSION_ARCHIVE_ROOT=${MW_HOST_LOCALDATA_ROOT:-/Users/andreas/code/modulewarden/localdata}/audits/sessions
MW_AUDIT_WORKSPACE_ROOT=${MW_HOST_LOCALDATA_ROOT:-/Users/andreas/code/modulewarden/localdata}/audits/workspaces
MW_HOST_LOCALDATA_ROOT=${MW_LOCALDATA_ROOT:-/Users/andreas/code/modulewarden/localdata}

# ─── Job Concurrency — High Parallelism ────────────────────────────────
# With Leonardo's vLLM on 4× A100 serving qwen3.6 27b, we can run many
# concurrent audit jobs. Agentic audits are I/O-bound (tool calls, web
# search), so the LLM handles parallel requests efficiently.
MW_JOB_CONCURRENCY_AUDIT_CONTAINER_EXEC=8
MW_JOB_CONCURRENCY_PACKAGE_REVIEW=4
MW_JOB_CONCURRENCY_EVIDENCE_POST_PROCESS=8

# ─── Web UI ────────────────────────────────────────────────────────────
VITE_MW_API_BASE_URL=http://localhost:8080

# ─── Failure notification webhook (optional) ───────────────────────────
# MW_FAILURE_WEBHOOK_URL=

# ─── Data directories ──────────────────────────────────────────────────
MW_LOCALDATA_ROOT=/Users/andreas/code/modulewarden/localdata
